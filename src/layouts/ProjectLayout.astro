---
/**
 * ProjectLayout.astro — Individual research project detail page.
 *
 * Features:
 *   - Title, institution, date, tech stack
 *   - Freeform content from Markdown body
 *   - Cross-referenced publications (via BibTeX keys in relatedPublications)
 *   - Tag chips
 *
 * Publications are resolved at build time by matching BibTeX citation keys
 * from the project frontmatter against the parsed bibliography.
 */
import BaseLayout from "./BaseLayout.astro";
import PubCard from "@components/PubCard.astro";
import Backlinks from "@components/Backlinks.astro";
import SEO from "@components/SEO.astro";
import type { CollectionEntry } from "astro:content";
import { parseBibliography } from "@utils/bibtex";
import { formatDate } from "@utils/dates";
import { getBacklinksForUrl } from "@utils/backlinks";
import { features } from "@data/settings";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, institution, date } = project.data;
const tags: string[] = project.data.tags;
const techStack: string[] = project.data.techStack;
const relatedPublications: string[] = project.data.relatedPublications ?? [];

const linkedPubs = relatedPublications && relatedPublications.length > 0
  ? (await parseBibliography()).filter((pub) =>
      relatedPublications.includes(pub.key),
    )
  : [];

/** Compute backlinks for this project at build time */
const pageUrl = `/projects/${project.id}/`;
const backlinks = features.backlinks ? await getBacklinksForUrl(pageUrl) : [];
---

<BaseLayout title={title} description={`${title} — ${institution}`} activeNav="projects">
  {/* JSON-LD CreativeWork schema */}
  <SEO
    slot="head"
    pageType="project"
    title={title}
    description={`${title} — ${institution}`}
    url={pageUrl}
    datePublished={date.toISOString()}
    tags={tags}
    institution={institution}
  />
  <article class="prose-container py-12" data-pagefind-body>
    <header class="mb-8">
      <a
        href="/projects/"
        class="mb-4 inline-block font-mono text-xs text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
        data-pagefind-ignore
      >
        ← Back to Projects
      </a>
      <h1 class="text-2xl font-semibold tracking-tight text-[var(--color-text)] md:text-3xl leading-tight" data-pagefind-meta="title">
        {title}
      </h1>
      {/* Pagefind filter for content type */}
      <data hidden data-pagefind-filter="type:project" />
      <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-[var(--color-muted)]">
        <span>{institution}</span>
        <span class="text-[var(--color-border)]">·</span>
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
      </div>
      {techStack.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {techStack.map((tech) => (
            <span class="rounded-sm border border-[var(--color-border)] px-2 py-0.5 font-mono text-[10px] text-[var(--color-muted)]">
              {tech}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>

    {/* Cross-referenced publications from BibTeX */}
    {linkedPubs.length > 0 && (
      <section class="mt-12 border-t border-[var(--color-border)] pt-8">
        <h2 class="mb-4 font-mono text-[11px] font-medium tracking-wider text-[var(--color-muted)] uppercase">
          Related Publications
        </h2>
        <div class="space-y-3">
          {linkedPubs.map((pub) => (
            <PubCard pub={pub} />
          ))}
        </div>
      </section>
    )}

    {/* Tags */}
    {tags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 font-mono text-[10px] text-[var(--color-muted)]">
            {tag}
          </span>
        ))}
      </div>
    )}

    {features.backlinks && backlinks.length > 0 && (
      <Backlinks backlinks={backlinks.map((b) => ({ title: b.sourceTitle, url: b.sourceUrl, context: b.context }))} />
    )}
  </article>
</BaseLayout>
