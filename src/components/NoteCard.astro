---
/**
 * NoteCard.astro — Digital garden note card component.
 *
 * Displays a card for note listing pages with:
 *   - Maturity emoji indicator
 *   - Title (linked to note page)
 *   - Description snippet
 *   - Date
 *   - Tags
 *
 * Follows the card pattern from Session 2 design system.
 */
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@utils/dates";
import { maturityConfig, type MaturityLevel } from "@utils/contentMaturity";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const { title, maturity, description, date } = note.data;
const tags: string[] = note.data.tags;
const config = maturityConfig[maturity as MaturityLevel];
---

<article
  class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-off)] px-5 py-4 transition-colors hover:border-[var(--color-accent-border)] hover:bg-[var(--color-accent-bg)]"

  data-pagefind-filter={`maturity:${maturity}`}
>
  <a href={`/notes/${note.id}/`} class="block no-underline">
    <div class="flex items-center gap-2">
      <span title={config.description} aria-label={config.label}>
        {config.emoji}
      </span>
      <h3 class="text-sm font-medium text-[var(--color-text)]">{title}</h3>
    </div>

    {description && (
      <p class="mt-1.5 text-xs leading-relaxed text-[var(--color-muted)] line-clamp-2">
        {description}
      </p>
    )}

    <div class="mt-2 flex items-center gap-2 text-[11px] text-[var(--color-muted)]">
      <time datetime={date.toISOString()} class="font-mono">
        {formatDate(date)}
      </time>
      <span class:list={["rounded-sm px-1.5 py-0.5 font-mono text-[10px]", config.textColor, config.bgColor]}>
        {config.label}
      </span>
    </div>
  </a>

  {tags.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="rounded-full border border-[var(--color-border)] px-2 py-0.5 font-mono text-[10px] text-[var(--color-muted)]">
          {tag}
        </span>
      ))}
    </div>
  )}
</article>
