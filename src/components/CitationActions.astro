---
/**
 * CitationActions.astro — Publication Action Buttons.
 *
 * Renders a horizontal cluster of action buttons for a publication.
 * Each button only appears if its corresponding data exists.
 *
 * Buttons: PDF, DOI, arXiv, Code, BibTeX (copy), Cite (copy APA).
 * BibTeX and Cite use the CopyButton React island (client:idle).
 *
 * Styled with Tailwind: small rounded buttons with icon + label, hover
 * states, glassmorphism container. Matches the terminal-label aesthetic.
 */
import type { Publication } from "@utils/bibtex";
import { formatCitation } from "@utils/bibtex";
import CopyButton from "@islands/CopyButton.tsx";

interface Props {
  pub: Publication;
}

const { pub } = Astro.props;
const apaCitation = formatCitation(pub, "apa");
---

<div class="flex flex-wrap gap-2">
  {/* PDF — external link to PDF file */}
  {pub.pdfPath && (
    <a
      href={pub.pdfPath}
      target="_blank"
      rel="noopener noreferrer"
      class="citation-btn"
      data-type="pdf"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <polyline points="14 2 14 8 20 8" />
        <line x1="16" y1="13" x2="8" y2="13" />
        <line x1="16" y1="17" x2="8" y2="17" />
      </svg>
      PDF
    </a>
  )}

  {/* DOI — link to DOI resolver */}
  {pub.doi && (
    <a
      href={`https://doi.org/${pub.doi}`}
      target="_blank"
      rel="noopener noreferrer"
      class="citation-btn"
      data-type="doi"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
      </svg>
      DOI
    </a>
  )}

  {/* arXiv — link to arXiv abstract */}
  {pub.arxivId && (
    <a
      href={`https://arxiv.org/abs/${pub.arxivId}`}
      target="_blank"
      rel="noopener noreferrer"
      class="citation-btn"
      data-type="arxiv"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
      </svg>
      arXiv
    </a>
  )}

  {/* Code — link to source repository */}
  {pub.codeUrl && (
    <a
      href={pub.codeUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="citation-btn"
      data-type="code"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="16 18 22 12 16 6" />
        <polyline points="8 6 2 12 8 18" />
      </svg>
      Code
    </a>
  )}

  {/* BibTeX — copy raw entry to clipboard */}
  <CopyButton
    client:idle
    text={pub.bibtexRaw}
    label="BibTeX"
  />

  {/* Cite — copy APA citation to clipboard */}
  <CopyButton
    client:idle
    text={apaCitation}
    label="Cite"
  />
</div>

<style>
  .citation-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }
  .citation-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-border);
    background-color: var(--color-accent-bg);
  }
  .citation-btn[data-type="pdf"]:hover {
    color: var(--color-success, #22c55e);
    border-color: var(--color-success, #22c55e);
  }
</style>
