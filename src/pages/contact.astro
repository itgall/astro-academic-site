---
/**
 * contact.astro — Contact page.
 *
 * Features:
 *   - Email with CSS-based obfuscation (reversed text + CSS correction)
 *     to reduce harvesting by naive scrapers. Not bulletproof, but
 *     stops the simplest bots without requiring JavaScript.
 *   - Office/lab address (update with your institution)
 *   - Links to ORCID, Google Scholar, GitHub, LinkedIn
 *   - No contact form — email links are sufficient and forms are bloat
 */
import PageLayout from "@layouts/PageLayout.astro";
import { siteMetadata } from "@data/meta";

/**
 * Reverse a string for CSS-based email obfuscation.
 * The CSS rule `direction: rtl; unicode-bidi: bidi-override;` on the
 * container visually reverses the text back to the correct reading order,
 * but the DOM contains the reversed string, foiling naive text scrapers.
 */
function reverseString(str: string): string {
  return str.split("").reverse().join("");
}

const emailReversed = reverseString(siteMetadata.contact.professionalEmail);

/** Academic profile links rendered as contact cards */
const profiles = [
  {
    label: "ORCID",
    href: `https://orcid.org/${siteMetadata.contact.orcid}`,
    value: siteMetadata.contact.orcid,
    description: "Researcher identifier",
  },
  {
    label: "Google Scholar",
    href: siteMetadata.contact.googleScholar,
    value: siteMetadata.name,
    description: "Publication profile",
  },
  {
    label: "GitHub",
    href: siteMetadata.contact.github,
    value: siteMetadata.contact.github.split("/").pop() ?? "GitHub",
    description: "Code repositories",
  },
  {
    label: "LinkedIn",
    href: siteMetadata.contact.linkedin,
    value: siteMetadata.contact.linkedinHandle,
    description: "Professional network",
  },
];
---

<PageLayout
  title="Contact"
  subtitle="Get in touch."
  activeNav="contact"
>
  <div class="max-w-lg">

    {/* ─── Email ──────────────────────────────────────────────────────── */}
    <section class="mb-10">
      <h2 class="mb-4 font-mono text-[11px] font-medium uppercase tracking-widest text-[var(--color-muted)] border-b border-[var(--color-border)] pb-2">
        Email
      </h2>
      <a
        href={`mailto:${siteMetadata.contact.professionalEmail}`}
        class="group flex items-center gap-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-off)] px-5 py-4 transition-colors hover:border-[var(--color-accent-border)] hover:bg-[var(--color-accent-bg)] no-underline"
      >
        <svg class="h-5 w-5 shrink-0 text-[var(--color-muted)] group-hover:text-[var(--color-accent)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        {/*
         * CSS email obfuscation: The text in the DOM is reversed.
         * The CSS `direction: rtl` + `unicode-bidi: bidi-override` renders
         * it visually correct. Naive scrapers see the reversed string.
         */}
        <span
          class="text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors"
          style="direction: rtl; unicode-bidi: bidi-override;"
        >
          {emailReversed}
        </span>
      </a>
    </section>

    {/* ─── Office ─────────────────────────────────────────────────────── */}
    <section class="mb-10">
      <h2 class="mb-4 font-mono text-[11px] font-medium uppercase tracking-widest text-[var(--color-muted)] border-b border-[var(--color-border)] pb-2">
        Office
      </h2>
      <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-off)] px-5 py-4">
        <p class="text-sm font-medium text-[var(--color-text)]">
          {siteMetadata.affiliations[0]?.name ?? "Your Lab"}
        </p>
        <p class="mt-1 text-sm text-[var(--color-muted)]">
          {siteMetadata.affiliations[0]?.parent ?? "Your University"}
        </p>
        <p class="text-sm text-[var(--color-muted)]">
          123 Your Street
        </p>
        <p class="text-sm text-[var(--color-muted)]">
          City, ST 00000
        </p>
      </div>
    </section>

    {/* ─── Academic Profiles ──────────────────────────────────────────── */}
    <section>
      <h2 class="mb-4 font-mono text-[11px] font-medium uppercase tracking-widest text-[var(--color-muted)] border-b border-[var(--color-border)] pb-2">
        Profiles
      </h2>
      <div class="space-y-1.5">
        {profiles.map((profile) => (
          <a
            href={profile.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-off)] px-5 py-3.5 transition-colors hover:border-[var(--color-accent-border)] hover:bg-[var(--color-accent-bg)] no-underline"
          >
            <div>
              <span class="block text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
                {profile.label}
              </span>
              <span class="block text-xs text-[var(--color-muted)]">
                {profile.description}
              </span>
            </div>
            <span class="font-mono text-[11px] text-[var(--color-muted)] group-hover:text-[var(--color-accent)] transition-colors">
              {profile.value}
            </span>
          </a>
        ))}
      </div>
    </section>

  </div>
</PageLayout>
