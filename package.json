{
  "name": "astro-academic-site",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-grade academic website built on Astro 6 — zero JS by default, BibTeX-driven publications engine, Google Scholar meta tags, sidenotes, backlinks, research graph.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "build:search": "astro build && npx pagefind --site dist",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,css,md,mdx}\"",
    "new:post": "tsx scripts/new-post.ts",
    "new:project": "tsx scripts/new-project.ts",
    "new:note": "tsx scripts/new-note.ts",
    "refresh:citations": "tsx scripts/refresh-citations.ts"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@retorquere/bibtex-parser": "^9.0.29",
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3": "^7.4.3",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.3",
    "d3": "^7.9.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.2.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "vite": "^7.3.1"
  }
}
